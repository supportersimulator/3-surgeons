#!/usr/bin/env bash
# MCP server launcher for the 3-Surgeons plugin.
# Resolves the Python environment automatically:
#   1. Plugin-local .venv/
#   2. User-level ~/.3surgeons/.venv/
#   3. System python (with three_surgeons on PYTHONPATH)
#
# Called by Claude Code via plugin.json mcpServers config.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Verify Python has >=3.10, mcp, and three_surgeons importable
has_mcp_runtime() {
    local py="$1"
    "$py" - <<'PY' >/dev/null 2>&1
import sys
if sys.version_info < (3, 10):
    raise SystemExit(1)
import mcp  # noqa: F401
import three_surgeons  # noqa: F401
PY
}

# 1. Plugin-local venv
if [ -f "${PLUGIN_ROOT}/.venv/bin/python" ]; then
    if has_mcp_runtime "${PLUGIN_ROOT}/.venv/bin/python"; then
        exec "${PLUGIN_ROOT}/.venv/bin/python" -m three_surgeons.mcp.server "$@"
    fi
fi

# 2. User-level venv
USER_VENV="${HOME}/.3surgeons/.venv/bin/python"
if [ -f "$USER_VENV" ]; then
    if has_mcp_runtime "$USER_VENV"; then
        exec "$USER_VENV" -m three_surgeons.mcp.server "$@"
    fi
fi

# 3. System python with PYTHONPATH fallback
# Add plugin root to PYTHONPATH so three_surgeons package is discoverable
export PYTHONPATH="${PLUGIN_ROOT}:${PYTHONPATH:-}"

# Try python3 first, then python
for PY in python3 python; do
    if command -v "$PY" >/dev/null 2>&1; then
        if has_mcp_runtime "$PY"; then
            exec "$PY" -m three_surgeons.mcp.server "$@"
        fi
    fi
done

# 4. Auto-bootstrap: try to create a venv and install
echo "3-Surgeons: No runtime found. Attempting auto-bootstrap..." >&2
for PY in python3 python; do
    if command -v "$PY" >/dev/null 2>&1; then
        PY_VER=$("$PY" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null || echo "0.0")
        if [ "$(echo "$PY_VER" | awk -F. '{print ($1 * 100 + $2)}')" -ge 310 ]; then
            BOOTSTRAP_VENV="${PLUGIN_ROOT}/.venv"
            echo "  Creating venv at ${BOOTSTRAP_VENV} ..." >&2
            if "$PY" -m venv "$BOOTSTRAP_VENV" 2>/dev/null; then
                EXTRAS="mcp"
                [ -n "${CONTEXTDNA_ADAPTER:-}" ] && EXTRAS="mcp,contextdna"
                echo "  Installing three-surgeons[${EXTRAS}] ..." >&2
                if "${BOOTSTRAP_VENV}/bin/pip" install -q -e "${PLUGIN_ROOT}[${EXTRAS}]" 2>/dev/null; then
                    echo "  Bootstrap complete." >&2
                    exec "${BOOTSTRAP_VENV}/bin/python" -m three_surgeons.mcp.server "$@"
                fi
            fi
            echo "  Bootstrap failed for $PY ($PY_VER)" >&2
        fi
    fi
done

# --- No runtime found — structured error output ---
cat >&2 <<DIAG
{
  "code": "3S-MCP-MISS",
  "passed": false,
  "message": "Cannot find Python >=3.10 with mcp and three_surgeons installed",
  "fix": "cd ${PLUGIN_ROOT} && python3 -m venv .venv && .venv/bin/pip install -e '.[mcp]'"
}
DIAG
exit 1
